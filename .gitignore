# Raw Kaggle data should not be redistributed -- excluded from the repo.
# Processed artifacts (SQLite db, feature table, production model) ARE
# committed despite being derived data: Streamlit Cloud's free tier has no
# persistent storage/database service and no way to run the Kaggle download +
# full training pipeline at deploy time, so the dashboard ships with these
# pre-built. Each is comfortably under GitHub's 100MB hard limit.
data/raw/*
!data/raw/.gitkeep
data/external/*
!data/external/.gitkeep

# Trained models (only the production model is committed; intermediate
# comparison artifacts like random_forest_global.joblib are 500MB+ and stay
# local-only)
models/*.pkl
models/*.h5
models/*.joblib
!models/.gitkeep
!models/best_model.joblib
!models/item_xgboost.joblib

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.Python
build/
dist/
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment variables / secrets
.env
.env.local

# Streamlit
.streamlit/secrets.toml

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Prophet
*.pkl

# Logs
*.log
