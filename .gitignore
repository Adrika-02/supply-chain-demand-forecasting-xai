# Data (raw Kaggle data should not be committed)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/external/*
!data/external/.gitkeep

# Database
db/*.sqlite
db/*.db
!db/.gitkeep

# Trained models (large binaries)
models/*.pkl
models/*.joblib
models/*.h5
!models/.gitkeep

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.Python
build/
dist/
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment variables / secrets
.env
.env.local

# Streamlit
.streamlit/secrets.toml

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Prophet
*.pkl

# Logs
*.log
